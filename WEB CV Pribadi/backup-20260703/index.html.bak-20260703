</nav>

<main id="main-content">

<!-- =====================================================================
     SECTION: HOME (HERO)
     ===================================================================== -->
<section class="hero" id="home">

  <!-- Dekorasi background: moving grid + particle + light glow (murni visual) -->
  <div class="hero__bg-decoration" aria-hidden="true">
    <div class="hero__bg-grid"></div>
    <div class="hero__bg-glow hero__bg-glow--1"></div>
    <div class="hero__bg-glow hero__bg-glow--2"></div>
    <canvas id="particleCanvas" class="hero__bg-particles"></canvas>
  </div>

  <div class="hero__inner">

    <!-- Foto profil dengan bingkai modern + glow -->
    <div class="hero__photo-frame" data-aos="zoom-in" data-aos-duration="800">
      <img src="images/profile.webp" alt="Foto profil Adhiim Ghaniiyu Ulul Hakiim" class="hero__photo">
    </div>

    <div class="hero__badge" data-aos="fade-up" data-aos-delay="100">
      <span class="hero__badge-dot"></span>
      AVAILABLE FOR HIRE
    </div>

    <h1 class="hero__name" data-aos="fade-up" data-aos-delay="150">
      ADHIIM GHANIIYU<br>ULUL HAKIIM
    </h1>

    <!-- Typing effect: 3 role berganti-ganti, dikendalikan oleh script.js -->
    <p class="hero__role">
      <span id="typedRole" class="hero__role-text"></span><span class="hero__role-cursor">|</span>
    </p>

    <p class="hero__lokasi" data-aos="fade-up" data-aos-delay="200">
      <i class="fa-solid fa-location-dot" aria-hidden="true"></i>
      Tuban, East Java, Indonesia
    </p>

    <div class="hero__cta" data-aos="fade-up" data-aos-delay="250">
      <a href="documents/surat-keterangan-lulus.pdf" class="btn btn--primary" download>
        <i class="fa-solid fa-download" aria-hidden="true"></i> Download CV
      </a>
      <a href="#contact" class="btn btn--outline">
        <i class="fa-solid fa-paper-plane" aria-hidden="true"></i> Contact Me
      </a>
    </div>

    <!-- Counter statistik -->
    <div class="hero__stats" data-aos="fade-up" data-aos-delay="300">
      <div class="hero__stat">
        <div class="hero__stat-number" data-count="5">0</div>
        <div class="hero__stat-label">Years Experience</div>
      </div>
      <div class="hero__stat">
        <div class="hero__stat-number" data-count="4">0</div>
        <div class="hero__stat-label">Companies</div>
      </div>
      <div class="hero__stat">
        <div class="hero__stat-number" data-count="6">0</div>
        <div class="hero__stat-label">Certificates</div>
      </div>
      <div class="hero__stat hero__stat--text">
        <div class="hero__stat-number hero__stat-number--text">S1</div>
        <div class="hero__stat-label">Information Systems</div>
      </div>
    </div>
  </div>

  <div class="hero__scroll-indicator" aria-hidden="true">
    <i class="fa-solid fa-chevron-down"></i>
  </div>
</section>


<!-- =====================================================================
     SECTION: ABOUT
     ===================================================================== -->
<section class="section" id="about">
  <div class="container">
    <div class="section-header" data-aos="fade-up">
      <span class="section-eyebrow">Tentang Saya</span>
      <h2 class="section-title">About Me</h2>
    </div>

    <div class="about__grid">
      <div class="about__photo-wrap" data-aos="fade-right">
        <img src="images/profile.webp" alt="Adhiim Ghaniiyu Ulul Hakiim" class="about__photo">
        <div class="about__photo-accent" aria-hidden="true"></div>
      </div>

      <div class="about__content" data-aos="fade-left">
        <p class="about__desc">
          I am an <strong>Information Systems graduate from Universitas Terbuka</strong> with
over four years of experience in warehousing, inventory, <strong>4 Years</strong> of experience
 in warehousing, inventory control, security, material distribution, operational administration,
 and data management.
        </p>
        <p class="about__desc">
          My combination of hands-on warehouse operations experience and an educational 
          background in information systems enables me to understand workflows firsthand while 
          maintaining a structured approach to accurate data management and administration.
        </p>

        <!-- Info singkat ala "kartu identitas profesional" -->
        <div class="about__info-grid">
          <div class="about__info-item">
            <span class="about__info-label">Full Name </span>
            <span class="about__info-value">Adhiim Ghaniiyu Ulul Hakiim</span>
          </div>
          <div class="about__info-item">
            <span class="about__info-label">Place and date of birth </span>
            <span class="about__info-value">Tuban, 03 July 1998</span>
          </div>
          <div class="about__info-item">
            <span class="about__info-label">Education </span>
            <span class="about__info-value">S1 Sistem Informasi</span>
          </div>
          <div class="about__info-item">
            <span class="about__info-label">Status</span>
            <span class="about__info-value">Available for Hire</span>
          </div>
        </div>

        <a href="documents/surat-keterangan-lulus.pdf" class="btn btn--primary" download>
          <i class="fa-solid fa-download" aria-hidden="true"></i> Download CV
        </a>
      </div>
    </div>
  </div>
</section>


