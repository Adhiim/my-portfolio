<!-- =====================================================================
     SECTION: EXPERIENCE
     ===================================================================== -->
<section class="section section--alt" id="experience">
  <div class="container">
    <div class="section-header" data-aos="fade-up">
      <span class="section-eyebrow">Carrer</span>
      <h2 class="section-title">Work Experience</h2>
    </div>

    <div class="timeline">

      <!-- Paling baru: Secure Garuda Indonesia -->
      <div class="timeline__item" data-aos="fade-right">
        <span class="timeline__dot" aria-hidden="true"></span>
        <div class="timeline__card">
          <span class="timeline__period">Jan 2024 &ndash; Nov 2024</span>
          <h3 class="timeline__title">Security</h3>
          <p class="timeline__subtitle">
            <strong>PT Secure Garuda Indonesia</strong> &middot;
            <i class="fa-solid fa-location-dot" aria-hidden="true"></i> WTC Surabaya,East Java
          </p>
          <p class="timeline__desc">
            Experienced in securing 16–20 operational points within a shopping center across 
            a 3-shift rotation to maintain a safe and orderly environment. Proven ability to 
            swiftly resolve visitor altercations, manage emergency medical evacuations, and 
            collaborate effectively within a 10–11 personnel team while coordinating with supervisors 
            and law enforcement in accordance with public security procedures.
          </p>
        </div>
      </div>

      <!-- Astra Honda Motor (2 kontrak digabung jadi 1 entri) -->
      <div class="timeline__item" data-aos="fade-left">
        <span class="timeline__dot" aria-hidden="true"></span>
        <div class="timeline__card">
          <span class="timeline__period">Sep 2019 &ndash; Mar 2023</span>
          <h3 class="timeline__title"> Warehouse Operator </h3>
          <p class="timeline__subtitle">
            <strong>PT Astra Honda Motor</strong> &middot;
            <i class="fa-solid fa-location-dot" aria-hidden="true"></i> Bekasi Regency, West Java
          </p>
          <p class="timeline__desc">
            Experienced in managing the distribution and inventory of thousands of spare parts 
            (including small, electric, big, export, and plastic parts) at Plant 3 to support 3 
            automotive production lines with a capacity of 1,000–1,200 units per shift. Proven track 
            record in conducting periodic stock takes, mitigating supply chain bottlenecks due to 
            production planning shifts, and coordinating with receiving teams for urgent material 
            prioritization, while actively training new operators within a large-scale team of 80–100 
            personnel per shift.
          </p>
        </div>
      </div>

      <!-- Gada Pratama / Sigap Prima Astrea -->
      <div class="timeline__item" data-aos="fade-right">
        <span class="timeline__dot" aria-hidden="true"></span>
        <div class="timeline__card">
          <span class="timeline__period">Feb 2019 &ndash; Aug 2019 </span>
          <h3 class="timeline__title">Security</h3>
          <p class="timeline__subtitle">
            <strong>PT Sigap Prima Astrea</strong> &middot;
            <i class="fa-solid fa-location-dot" aria-hidden="true"></i> Manggarai Station, South Jakarta
          </p>
          <p class="timeline__desc">
            Experienced in securing KRL Commuter Line trips on the Jakarta – Bogor round-trip (PP) route,
             managing approximately 3 round trips per operational shift to ensure passenger safety and 
             order. Proven ability to swiftly handle reported harassment incidents, maintain onboard 
             situational stability within a 4-personnel security team, and seamlessly coordinate with 
             destination station guards adhering to public transportation safety protocols.
          </p>
        </div>
      </div>
       <!-- Serba Sambal  -->
      <div class="timeline__item" data-aos="fade-right">
        <span class="timeline__dot" aria-hidden="true"></span>
        <div class="timeline__card">
          <span class="timeline__period">Jun 2016 &ndash; Des 2016 </span>
          <h3 class="timeline__title">Resto Manager</h3>
          <p class="timeline__subtitle">
            <strong>Resto Serba Sambal</strong> &middot;
            <i class="fa-solid fa-location-dot" aria-hidden="true"></i> Lamongan ,East Java
          </p>
          <p class="timeline__desc">
            Experienced in managing daily operations, financial administration, and raw material 
            inventory control for a restaurant with a capacity of >50 customers and a daily turnover 
            of $\pm$Rp4,000,000. Proven analytical skills in stock evaluation, proactive supply chain 
            bottleneck mitigation, and team leadership for 8 personnel, including managing payroll and 
            attendance records.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>


