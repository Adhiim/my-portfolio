<!DOCTYPE html>
<!--
  =========================================================================
  FILE: index.html
  PEMILIK: Adhiim Ghaniiyu Ulul Hakiim
  FUNGSI: Halaman utama portfolio (Single Page). Semua section ada di
          SATU file ini (Home, About, Skills, Education, Experience,
          Portfolio, Certificates, Contact, Footer), pengunjung pindah
          section dengan scroll atau klik menu navbar.

  CARA EDIT TEKS: Cari teks yang ingin diubah langsung di file ini
  (Ctrl+F), ganti teksnya, simpan. Tidak perlu paham coding mendalam
  untuk sekadar mengganti kata-kata.

  CARA EDIT WARNA/STYLE: Buka assets/css/style.css
  CARA EDIT INTERAKSI/ANIMASI: Buka assets/js/script.js
  =========================================================================
-->
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <!-- ===================================================================
       SEO META TAGS — membantu Google & media sosial memahami halaman ini
       =================================================================== -->
  <title>Adhiim Ghaniiyu Ulul Hakiim | Warehouse Operations & Information Systems</title>
  <meta name="description" content="Portfolio profesional Adhiim Ghaniiyu Ulul Hakiim — Lulusan Sistem Informasi dengan pengalaman 4+ tahun di bidang Warehouse Operations, Inventory Control, dan Administrasi Operasional.">
  <meta name="keywords" content="warehouse, inventory control, sistem informasi, operator forklift, supply chain, portfolio, CV">
  <meta name="author" content="Adhiim Ghaniiyu Ulul Hakiim">

  <!-- Open Graph: tampilan saat link ini dibagikan ke WhatsApp/LinkedIn dll -->
  <meta property="og:title" content="Adhiim Ghaniiyu Ulul Hakiim | Warehouse & Information Systems">
  <meta property="og:description" content="Lulusan Sistem Informasi dengan pengalaman di Warehouse Operations & Inventory Control.">
  <meta property="og:type" content="website">

  <!-- Favicon sederhana berupa emoji kotak gudang, bisa diganti file .ico nanti -->
  <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>📦</text></svg>">

  <!-- ===================================================================
       FONT & ICON
       =================================================================== -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <!-- Sora = font display untuk judul besar (karakter tegas, modern, geometris)
       Inter = font body untuk paragraf (sangat mudah dibaca di layar)
       JetBrains Mono = font untuk label kecil/data teknis (kesan presisi) -->
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700;800&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

  <!-- AOS (Animate On Scroll) - library animasi reveal saat scroll -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.css">

  <!-- CSS utama -->
  <link rel="stylesheet" href="style.css">
</head>
<body>

<!-- Skip link untuk aksesibilitas keyboard -->
<a href="#main-content" class="skip-link">Lompat ke konten utama</a>

