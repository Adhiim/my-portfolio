<section class="section section--alt" id="certificates">
  <div class="container">
    <div class="section-header" data-aos="fade-up">
      <span class="section-eyebrow">Legalitas</span>
      <h2 class="section-title">Certificates</h2>
    </div>

    <div class="cert__grid">

      <div class="cert-card" data-aos="zoom-in" data-aos-delay="0">
        <div class="cert-card__icon"><i class="fa-solid fa-truck-ramp-box"></i></div>
        <h3 class="cert-card__title">Lisensi K3 Operator Forklift Kelas II &amp; SIO Forklift</h3>
        <p class="cert-card__issuer">Kementerian Ketenagakerjaan RI</p>
